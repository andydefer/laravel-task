<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         executionOrder="random"
         resolveDependencies="true">
    
    <testsuites>
        <!-- Unit tests (fast, no Laravel) -->
       <!--  <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
            <directory suffix="Test.php">./tests/*/Unit</directory>
        </testsuite> -->
        
        <!-- Integration tests (with Laravel and database) -->
        <testsuite name="Integration">
            <directory suffix="Test.php">./tests/Integration</directory>
            <directory suffix="Test.php">./tests/*/Integration</directory>
        </testsuite>
    </testsuites>
    
    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>src/config</directory>
            <directory>src/Exceptions</directory>
        </exclude>
    </source>
    
    <php>
        <!-- Test environment -->
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="APP_KEY" value="base64:testkey1234567890testkey1234567890="/>
        
        <!-- Database (SQLite in-memory) -->
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        
        <!-- Cache disabled -->
        <env name="CACHE_DRIVER" value="array"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        
        <!-- Mail disabled -->
        <env name="MAIL_MAILER" value="array"/>
        
        <!-- Broadcast disabled -->
        <env name="BROADCAST_DRIVER" value="log"/>
        
        <!-- Task storage (temporary) -->
        <env name="TASKS_STORAGE_PATH" value="/tmp/laravel_task_tests"/>
        
        <!-- Logger storage (temporary) -->
        <env name="LOGGER_PATH" value="/tmp/laravel_logger_tests"/>
        <env name="LOGGER_RETENTION_DAYS" value="7"/>
        
        <!-- Timezone for tests -->
        <env name="APP_TIMEZONE" value="UTC"/>
        
        <!-- Bcrypt rounds (minimal for tests) -->
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="HASH_VERIFY" value="false"/>
    </php>
    
</phpunit>