{
    "name": "andydefer/laravel-task",
    "description": "A lightweight, file-based task system for Laravel with async execution, recurring tasks, and JSONL storage",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Defer",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "ramsey/uuid": "^4.7",
        "andydefer/laravel-logger": "^3.9.2",
        "andydefer/laravel-repository": "^2.10.3",
        "andydefer/laravel-directive": "^3.54.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.29",
        "laravel/tinker": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\Task\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\Task\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\Task\\TaskServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
